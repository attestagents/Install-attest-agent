  "bin": {
    "attest-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "mcp-server",
    "x402",
    "ap2",
    "l402",
    "mpp",
    "http-402",
    "agent-payments",
    "agentic-payments",
    "ai-agents",
    "payments",
    "security",
    "trust",
    "scanner",
    "attest",
    "anthropic",
    "claude",
    "cursor"
  ],
  "author": "Attest (https://attestagent.org)",
  "license": "MIT",
  "homepage": "https://attestagent.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attestagents/Install-attest-agent.git"
  },
  "bugs": {
    "url": "https://github.com/attestagents/Install-attest-agent/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3"
  }
}
