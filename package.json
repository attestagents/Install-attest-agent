{
  "name": "attest-mcp",
  "version": "1.0.0",
  "mcpName": "io.github.attestagents/attest-mcp",
  "description": "MCP server for Attest — scan agent payment endpoints (x402, MPP, AP2, L402, HTTP 402) and get a trust grade A–F with a safety verdict before your AI agent authorizes a payment.",
